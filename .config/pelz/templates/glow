{
    "document": {
        "block_prefix": "\n",
        "block_suffix": "\n",
        "color": "#{{fg}}",
        "margin": 2
    },
    "block_quote": {
        "indent": 1,
        "indent_token": "│ "
    },
    "paragraph": {},
    "list": {
        "level_indent": 2
    },
    "heading": {
        "block_suffix": "\n",
        "color": "#{{fgBright}}",
        "bold": true
    },
    "h1": {
        "prefix": " ",
        "suffix": " ",
        "block_suffix": "\n-------------------------\n",
        "bold": true
    },
    "h2": {
        "prefix": "## "
    },
    "h3": {
        "prefix": "### "
    },
    "h4": {
        "prefix": "#### "
    },
    "h5": {
        "prefix": "##### "
    },
    "h6": {
        "prefix": "###### ",
        "bold": false
    },
    "text": {},
    "strikethrough": {
        "crossed_out": true
    },
    "emph": {
        "italic": true
    },
    "strong": {
        "bold": true
    },
    "hr": {
        "color": "#{{grey1}}",
        "format": "\n--------------------------------\n"
    },
    "item": {
        "block_prefix": "• "
    },
    "enumeration": {
        "block_prefix": ". "
    },
    "task": {
        "ticked": "[✓] ",
        "unticked": "[ ] "
    },
    "link": {
        "color": "#{{blue}}",
        "underline": true
    },
    "link_text": {
        "color": "#{{greenDim}}",
        "bold": true
    },
    "image": {
        "color": "#{{magenta}}",
        "underline": true
    },
    "image_text": {
        "color": "#{{magentaDim}}",
        "format": "[Image] {{.text}} →"
    },
    "code": {
        "prefix": " ",
        "suffix": " ",
        "color": "#{{red}}",
        "background_color": "#{{bg3}}"
    },
    "code_block": {
        "color": "#{{fg}}",
        "block_prefix": "\n````````````````````````````````\n",
        "block_suffix": "\n````````````````````````````````\n",
        "background_color": "#{{bg0}}",
        "chroma": {
            "text": {
                "color": "#{{fg}}"
            },
            "error": {
                "color": "#{{fgBright}}",
                "background_color": "#{{bgRed}}"
            },
            "comment": {
                "color": "#{{grey0}}",
                "italic": true
            },
            "comment_preproc": {
                "color": "#{{grey0}}"
            },
            "keyword": {
                "color": "#{{red}}",
                "bold": true
            },
            "keyword_reserved": {
                "color": "#{{red}}"
            },
            "keyword_namespace": {
                "color": "#{{red}}"
            },
            "keyword_type": {
                "color": "#{{yellow}}",
                "bold": false
            },
            "operator": {
                "color": "#{{orange}}"
            },
            "punctuation": {
                "color": "#{{fg}}"
            },
            "name": {
                "color": "#{{fg}}"
            },
            "name_builtin": {
                "color": "#{{magenta}}"
            },
            "name_tag": {
                "color": "#{{green}}"
            },
            "name_attribute": {
                "color": "#{{cyan}}"
            },
            "name_class": {
                "color": "#{{fg}}",
                "bold": true
            },
            "name_constant": {},
            "name_decorator": {
                "color": "#{{fg}}"
            },
            "name_exception": {},
            "name_function": {
                "color": "#{{cyan}}"
            },
            "name_other": {},
            "literal": {},
            "literal_number": {
                "color": "#{{magenta}}"
            },
            "literal_date": {},
            "literal_string": {
                "color": "#{{green}}"
            },
            "literal_string_escape": {
                "color": "#{{yellowBright}}",
                "bold": true
            },
            "generic_deleted": {
                "color": "#FD5B5B"
            },
            "generic_emph": {
                "italic": true
            },
            "generic_inserted": {
                "color": "#00D787"
            },
            "generic_strong": {
                "bold": true
            },
            "generic_subheading": {
                "color": "#{{grey2}}"
            },
            "background": {
                "background_color": "#{{bg}}"
            }
        }
    },
    "table": {},
    "definition_list": {},
    "definition_term": {},
    "definition_description": {
        "block_prefix": "\n🠶 "
    },
    "html_block": {},
    "html_span": {}
}
