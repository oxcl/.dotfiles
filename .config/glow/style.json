{
    "document": {
        "block_prefix": "\n",
        "block_suffix": "\n",
        "color": "#d4be98",
        "margin": 2
    },
    "block_quote": {
        "indent": 1,
        "indent_token": "│ "
    },
    "paragraph": {},
    "list": {
        "level_indent": 2
    },
    "heading": {
        "block_suffix": "\n",
        "color": "#ddc7a1",
        "bold": true
    },
    "h1": {
        "prefix": " ",
        "suffix": " ",
        "block_suffix": "\n-------------------------\n",
        "bold": true
    },
    "h2": {
        "prefix": "## "
    },
    "h3": {
        "prefix": "### "
    },
    "h4": {
        "prefix": "#### "
    },
    "h5": {
        "prefix": "##### "
    },
    "h6": {
        "prefix": "###### ",
        "bold": false
    },
    "text": {},
    "strikethrough": {
        "crossed_out": true
    },
    "emph": {
        "italic": true
    },
    "strong": {
        "bold": true
    },
    "hr": {
        "color": "#928374",
        "format": "\n--------------------------------\n"
    },
    "item": {
        "block_prefix": "• "
    },
    "enumeration": {
        "block_prefix": ". "
    },
    "task": {
        "ticked": "[✓] ",
        "unticked": "[ ] "
    },
    "link": {
        "color": "#7daea3",
        "underline": true
    },
    "link_text": {
        "color": "#8f9a52",
        "bold": true
    },
    "image": {
        "color": "#d3869b",
        "underline": true
    },
    "image_text": {
        "color": "#ab6c7d",
        "format": "[Image] {{.text}} →"
    },
    "code": {
        "prefix": " ",
        "suffix": " ",
        "color": "#ea6962",
        "background_color": "#32302f"
    },
    "code_block": {
        "color": "#d4be98",
        "block_prefix": "\n````````````````````````````````\n",
        "block_suffix": "\n````````````````````````````````\n",
        "background_color": "#131414",
        "chroma": {
            "text": {
                "color": "#d4be98"
            },
            "error": {
                "color": "#ddc7a1",
                "background_color": "#3c1f1e"
            },
            "comment": {
                "color": "#7c6f64",
                "italic": true
            },
            "comment_preproc": {
                "color": "#7c6f64"
            },
            "keyword": {
                "color": "#ea6962",
                "bold": true
            },
            "keyword_reserved": {
                "color": "#ea6962"
            },
            "keyword_namespace": {
                "color": "#ea6962"
            },
            "keyword_type": {
                "color": "#d8a657",
                "bold": false
            },
            "operator": {
                "color": "#e78a4e"
            },
            "punctuation": {
                "color": "#d4be98"
            },
            "name": {
                "color": "#d4be98"
            },
            "name_builtin": {
                "color": "#d3869b"
            },
            "name_tag": {
                "color": "#a9b665"
            },
            "name_attribute": {
                "color": "#89b482"
            },
            "name_class": {
                "color": "#d4be98",
                "bold": true
            },
            "name_constant": {},
            "name_decorator": {
                "color": "#d4be98"
            },
            "name_exception": {},
            "name_function": {
                "color": "#89b482"
            },
            "name_other": {},
            "literal": {},
            "literal_number": {
                "color": "#d3869b"
            },
            "literal_date": {},
            "literal_string": {
                "color": "#a9b665"
            },
            "literal_string_escape": {
                "color": "#deb472",
                "bold": true
            },
            "generic_deleted": {
                "color": "#FD5B5B"
            },
            "generic_emph": {
                "italic": true
            },
            "generic_inserted": {
                "color": "#00D787"
            },
            "generic_strong": {
                "bold": true
            },
            "generic_subheading": {
                "color": "#a89984"
            },
            "background": {
                "background_color": "#202020"
            }
        }
    },
    "table": {},
    "definition_list": {},
    "definition_term": {},
    "definition_description": {
        "block_prefix": "\n🠶 "
    },
    "html_block": {},
    "html_span": {}
}
