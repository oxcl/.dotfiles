#!/bin/sh
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: vibmax claim <issue-id>"
  echo "Claim a specific task and show its details with phase instructions."
  exit 0
fi

ISSUE_ID="$1"

if [ -z "$ISSUE_ID" ]; then
  echo "Error: issue ID required"
  echo "Usage: vibmax claim <issue-id>"
  exit 1
fi

# Claim the task
bd update "$ISSUE_ID" --claim --json >/dev/null 2>&1

# Get the issue details with labels
PHASE=$(bd list --json | jq --arg id "$ISSUE_ID" -r '.[] | select(.id == $id) | .labels[]? | select(startswith("phase:")) | split(":")[1]')

# Show the issue details (includes notes)
bd show "$ISSUE_ID"

# Append instructions if file exists
if [ -n "$PHASE" ] && [ -f ".beads/task-instructions/${PHASE}.md" ]; then
  INSTRUCTIONS_FILE=".beads/task-instructions/${PHASE}.md"
elif [ -n "$PHASE" ] && [ -f "$HOME/.beads/task-instructions/${PHASE}.md" ]; then
  INSTRUCTIONS_FILE="$HOME/.beads/task-instructions/${PHASE}.md"
fi

if [ -n "$INSTRUCTIONS_FILE" ] && [ -s "$INSTRUCTIONS_FILE" ]; then
  echo ""
  echo "## Task Instructions"
  echo ""
  cat "$INSTRUCTIONS_FILE"
fi
