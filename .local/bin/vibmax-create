#!/bin/sh
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: vibmax-create <name> <description> [--link id] [--link id]..."
  echo "Pour vibmax molecule and claim vision task."
  echo ""
  echo "Options:"
  echo "  --link <id>   Link related issues (can be repeated)"
  echo ""
  echo "Examples:"
  echo "  vibmax-create \"auth-system\" \"JWT authentication for API\""
  echo "  vibmax-create \"auth-system\" \"JWT auth\" --link bd-abc123 --link bd-def456"
  exit 0
fi

name="$1"
description="$2"
shift 2

LINK_ISSUES=""
while [ $# -gt 0 ]; do
  case "$1" in
    --link)
      if [ -n "$LINK_ISSUES" ]; then
        LINK_ISSUES="${LINK_ISSUES} $2"
      else
        LINK_ISSUES="$2"
      fi
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

if [ -z "$name" ] || [ -z "$description" ]; then
  echo "Error: name and description required"
  echo "Usage: vibmax-create <name> <description> [--link id] [--link id]..."
  exit 1
fi

# Check if beads is initialized
if ! bd stats --json >/dev/null 2>&1; then
  echo "Error: beads is not initialized in this directory."
  echo "Run 'vibmax init' first."
  exit 1
fi

POUR_JSON=$(bd mol pour vibmax --var vibmax_name="$name" --var vibmax_description="$description" --json)

# Check if pour succeeded
MOLECULE_ID=$(echo "$POUR_JSON" | jq -r '.id_mapping.vibmax // empty')
if [ -z "$MOLECULE_ID" ]; then
  echo "Error: failed to pour molecule"
  echo "$POUR_JSON" | jq -r '.error // "unknown error"'
  exit 1
fi

VISION_ID=$(echo "$POUR_JSON" | jq -r '.id_mapping["vibmax.vision"]')
echo "Molecule: $MOLECULE_ID"

# Add phase labels to each step
bd list --parent "$MOLECULE_ID" --json | jq -r '.[] | "\(.id) \(.title)"' | while read -r issue_id title; do
  case "$title" in
    "Vision:"*) bd label add "$issue_id" "phase:vision" --json >/dev/null ;;
    "Integrate") bd label add "$issue_id" "phase:integrate" --json >/dev/null ;;
    "Blueprint") bd label add "$issue_id" "phase:blueprint" --json >/dev/null ;;
    "Multiplex") bd label add "$issue_id" "phase:multiplex" --json >/dev/null ;;
    "Action") bd label add "$issue_id" "phase:action" --json >/dev/null ;;
    "Examine") bd label add "$issue_id" "phase:examine" --json >/dev/null ;;
  esac
done

for issue_id in $LINK_ISSUES; do
  bd dep add "$MOLECULE_ID" "$issue_id" --type related
  echo "Linked: $issue_id"
done

# Claim the vision task
vibmax claim "$VISION_ID"
