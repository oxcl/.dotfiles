#!/bin/sh
usage() {
  echo "Usage: vibmax <command> [args...]"
  echo ""
  echo "Commands:"
  echo "  check-init       Check if beads is set up"
  echo "  init             Initialize beads"
  echo "  find-similar     Search for related issues"
  echo "  create           Pour vibmax molecule"
  echo "  claim            Claim next ready task"
  echo "  done             Show cleanup instructions for completing a task"
  echo "  close            Close a task and pass work to next step"
  echo ""
  echo "Use 'vibmax <command> --help' for more info on a command."
}

if [ $# -eq 0 ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  usage
  exit 0
fi

command="$1"
shift

case "$command" in
  check-init)   vibmax-check-init "$@" ;;
  init)         vibmax-init "$@" ;;
  find-similar) vibmax-find-similar "$@" ;;
  create)       vibmax-create "$@" ;;
  claim)        vibmax-claim "$@" ;;
  done)         vibmax-done "$@" ;;
  close)        vibmax-close "$@" ;;
  *)
    echo "Unknown command: $command"
    usage
    exit 1
    ;;
esac
