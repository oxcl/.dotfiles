#!/bin/sh
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
  echo "Usage: vibmax-init [--stealth]"
  echo "Initialize beads in the current project."
  echo ""
  echo "Options:"
  echo "  --stealth   Skip agents and run silently"
  exit 0
fi

if [ -d .beads ]; then
  echo "Already initialized"
  exit 0
fi

# Initialize beads
if [ "$1" = "--stealth" ]; then
  bd init --skip-agents --stealth
else
  bd init --skip-agents
fi

# Clean up
rm -f .beads/README.md
rm -rf .claude/
rm -f .beads/hooks/prepare-commit-msg

# Amend the commit
git add -A
git commit --amend --no-edit

# Register with vibmax server if running
VIBMAX_PORT="${VIBMAX_PORT:-4097}"
PROJECT_PATH="$(pwd)"
if curl -sf "http://localhost:${VIBMAX_PORT}/health" >/dev/null 2>&1; then
  if curl -sf -X POST "http://localhost:${VIBMAX_PORT}/projects/register" \
    -H "Content-Type: application/json" \
    -d "{\"path\": \"${PROJECT_PATH}\"}" >/dev/null 2>&1; then
    echo "Registered with vibmax server"
  else
    echo "Warning: failed to register with vibmax server"
  fi
else
  echo "Note: vibmax server not running, skipping registration"
fi

echo "Beads initialized"
