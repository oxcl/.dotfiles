#!/usr/bin/env bash
printf "FG0             " && showcolor $MY_THEME_FG0            
printf "FG              " && showcolor $MY_THEME_FG		   
printf "FG1             " && showcolor $MY_THEME_FG1		   
printf "RED             " && showcolor $MY_THEME_RED		   
printf "ORANGE          " && showcolor $MY_THEME_ORANGE	   
printf "YELLOW          " && showcolor $MY_THEME_YELLOW	   
printf "GREEN           " && showcolor $MY_THEME_GREEN          
printf "AQUA            " && showcolor $MY_THEME_AQUA	   
printf "BLUE            " && showcolor $MY_THEME_BLUE	   
printf "PURPLE          " && showcolor $MY_THEME_PURPLE	   
printf "RED_SUBTLE      " && showcolor $MY_THEME_RED_SUBTLE	   
printf "ORANGE_SUBTLE   " && showcolor $MY_THEME_ORANGE_SUBTLE  
printf "YELLOW_SUBTLE   " && showcolor $MY_THEME_YELLOW_SUBTLE  
printf "GREEN_SUBTLE    " && showcolor $MY_THEME_GREEN_SUBTLE   
printf "AQUA_SUBTLE     " && showcolor $MY_THEME_AQUA_SUBTLE	   
printf "BLUE_SUBTLE     " && showcolor $MY_THEME_BLUE_SUBTLE    
printf "PURPLE_SUBTLE   " && showcolor $MY_THEME_PURPLE_SUBTLE
echo
printf "BG_DIM          " && showcolor $MY_THEME_BG_DIM
printf "BG0             " && showcolor $MY_THEME_BG0
printf "BG              " && showcolor $MY_THEME_BG
printf "BG1             " && showcolor $MY_THEME_BG1
printf "BG2             " && showcolor $MY_THEME_BG2
printf "BG3             " && showcolor $MY_THEME_BG3
printf "BG4             " && showcolor $MY_THEME_BG4
printf "BG5             " && showcolor $MY_THEME_BG5
printf "BG6             " && showcolor $MY_THEME_BG6
printf "BG7             " && showcolor $MY_THEME_BG7
printf "BG8             " && showcolor $MY_THEME_BG8
echo
printf "BG_GREEN        " && showcolor $MY_THEME_BG_GREEN
printf "BG_GREEN_SUBTLE " && showcolor $MY_THEME_BG_GREEN_SUBTLE
printf "BG_RED          " && showcolor $MY_THEME_BG_RED
printf "BG_RED_SUBTLE   " && showcolor $MY_THEME_BG_RED_SUBTLE
printf "BG_BLUE         " && showcolor $MY_THEME_BG_BLUE
printf "BG_BLUE_SUBTLE  " && showcolor $MY_THEME_BG_BLUE_SUBTLE
printf "BG_YELLOW       " && showcolor $MY_THEME_BG_YELLOW
