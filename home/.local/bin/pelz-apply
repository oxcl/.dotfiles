#!/usr/bin/env bash
[[ -z "$MY_THEME" ]] && export MY_THEME="gruvbox_material_dark_soft"

pelz alacritty $MY_THEME > $HOME/.dotfiles/home/.config/alacritty/theme.toml
pelz Xresources $MY_THEME > $HOME/.dotfiles/home/.config/x11/theme
pelz wezterm $MY_THEME > $HOME/.dotfiles/home/.config/wezterm/theme.lua
