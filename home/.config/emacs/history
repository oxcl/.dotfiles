;; -*- mode: emacs-lisp; coding: utf-8-unix -*-
;; Minibuffer history file, automatically generated by ‘savehist’.

(setq savehist-minibuffer-history-variables '(query-replace-history minibuffer-history extended-command-history file-name-history))
(setq query-replace-history '("#+begin_src elisp :tangle no" "#\\+begin_src \\w*$"))
(setq extended-command-history '("replace-regexp"))
(setq file-name-history '("~/.config/emacs/config.org"))
