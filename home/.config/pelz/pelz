 -e "s/{{bg8}}/$bg8/g"\
 -e "s/{{fgDim}}/$fgDim/g"\
 -e "s/{{fgBright}}/$fgBright/g"\
 -e "s/{{whiteDim}}/$whiteDim/g"\
 -e "s/{{redDim}}/$redDim/g"\
 -e "s/{{greenDim}}/$greenDim/g"\
 -e "s/{{yellowDim}}/$yellowDim/g"\
 -e "s/{{blueDim}}/$blueDim/g"\
 -e "s/{{magentaDim}}/$magentaDim/g"\
